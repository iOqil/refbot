# Bot token (BotFather dan olinadi)
BOT_TOKEN=1234567890:ABCDEFabcdef1234567890

# Admin Telegram ID lar (vergul bilan ajrating)
ADMIN_IDS=123456789,987654321

# Majburiy kanallar (vergul bilan ajrating)
REQUIRED_CHANNELS=@channel1,@channel2

# MySQL sozlamalari
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=refbot
MYSQL_PASSWORD=strong_password_here
MYSQL_DB=refbot_db
MYSQL_ROOT_PASSWORD=root_strong_password_here

# Laravel formati bilan ham ishlaydi (alternativ):
# DB_HOST=192.168.1.100:3306
# DB_PORT=3306
# DB_DATABASE=db_name_here
# DB_USERNAME=db_user_here
# DB_PASSWORD=password_here
